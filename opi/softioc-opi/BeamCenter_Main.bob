  <widget type="rectangle" version="2.0.0"><name>a3b</name><x>1180</x><y>404</y><width>320</width><height>94</height><background_color><color red="255" green="244" blue="230"></color></background_color></widget>
  <widget type="label" version="2.0.0"><name>a3t</name><text>3. Compute error = target - beam</text><x>1194</x><y>416</y><width>250</width><height>22</height><font><font family="Liberation Sans" style="BOLD" size="15.0"></font></font></widget>
  <widget type="label" version="2.0.0"><name>a3l</name><text>errX / errY</text><x>1196</x><y>450</y><width>90</width><height>22</height></widget>
