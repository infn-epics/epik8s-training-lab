  <widget type="textupdate" version="2.0.0"><name>a2y</name><pv_name>$(CAMERA):Overlay1:1:PositionY_RBV</pv_name><x>1380</x><y>300</y><width>72</width><height>26</height><precision>0</precision></widget>
  <widget type="label" version="2.0.0"><name>a2l2</name><text>SizeX / SizeY</text><x>1196</x><y>336</y><width>100</width><height>22</height></widget>
