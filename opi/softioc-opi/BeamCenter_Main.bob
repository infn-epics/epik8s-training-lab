  <widget type="textupdate" version="2.0.0"><name>opx</name><pv_name>$(CAMERA):Overlay1:1:PositionX_RBV</pv_name><x>150</x><y>594</y><width>100</width><height>26</height><precision>0</precision></widget>
  <widget type="label" version="2.0.0"><name>s6</name><text>Overlay PosY</text><x>34</x><y>630</y><width>100</width><height>22</height></widget>
