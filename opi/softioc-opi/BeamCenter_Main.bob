  <widget type="label" version="2.0.0"><name>arrow3</name><text>--&gt;</text><x>1330</x><y>502</y><width>60</width><height>24</height><font><font family="Liberation Sans" style="BOLD" size="18.0"></font></font></widget>

  <widget type="rectangle" version="2.0.0"><name>a4b</name><x>1180</x><y>532</y><width>320</width><height>94</height><background_color><color red="244" green="236" blue="255"></color></background_color></widget>
