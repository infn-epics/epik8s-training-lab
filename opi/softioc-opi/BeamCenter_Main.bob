  <widget type="label" version="2.0.0"><name>s11</name><text>DMOV X/Y</text><x>34</x><y>812</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>dmovx</name><pv_name>$(MOTX).DMOV</pv_name><x>150</x><y>808</y><width>45</width><height>26</height></widget>
