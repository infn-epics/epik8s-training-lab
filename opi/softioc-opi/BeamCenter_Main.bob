  <widget type="action_button" version="3.0.0">
    <name>open-camera</name>
    <text>Open Camera Screen</text>
    <x>420</x>
    <y>698</y>
    <width>180</width>
    <height>32</height>
    <actions>
      <action type="open_display">
        <description>Open camera</description>
        <macros>
          <P>$(DEVICE)</P>
          <R>$(CAM)</R>
          <NAME>$(CAM)</NAME>
          <DEVICE>$(DEVICE)</DEVICE>
          <CAM>$(CAM)</CAM>
          <TYPE>camera</TYPE>
          <ZONE>SIMLAB</ZONE>
          <HW>camera</HW>
          <HCAM>$(CAMERA):cam1:</HCAM>
          <HDEVICE>$(CAMERA):</HDEVICE>
          <HIMAGE>$(CAMERA):image1:</HIMAGE>
          <HPROC>$(CAMERA):Proc1:</HPROC>
          <HROI>$(CAMERA):ROI1:</HROI>
          <HSTATS>$(CAMERA):Stats1:</HSTATS>
          <HTRANS>$(CAMERA):Trans1:</HTRANS>
          <OPI>Camera_Main.bob</OPI>
        </macros>
        <file>../epik8s-opi/unicam-opi/Camera_Main.bob</file>
        <target>window</target>
      </action>
    </actions>
    <background_color><color red="60" green="120" blue="200"></color></background_color>
    <foreground_color><color red="255" green="255" blue="255"></color></foreground_color>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>open-motx</name>
    <text>Open HMIR</text>
    <x>618</x>
    <y>698</y>
    <width>120</width>
    <height>32</height>
    <actions>
      <action type="open_display">
        <description>Open HMIR</description>
        <macros>
          <P>$(MOTX_P)</P>
          <R>$(MOTX_R)</R>
        </macros>
        <file>../epik8s-opi/unimot-opi/motor-asyn/Motor_Main.bob</file>
        <target>window</target>
      </action>
    </actions>
    <background_color><color red="30" green="110" blue="60"></color></background_color>
    <foreground_color><color red="255" green="255" blue="255"></color></foreground_color>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>open-moty</name>
    <text>Open VMIR</text>
    <x>752</x>
    <y>698</y>
    <width>120</width>
    <height>32</height>
    <actions>
      <action type="open_display">
        <description>Open VMIR</description>
        <macros>
          <P>$(MOTY_P)</P>
          <R>$(MOTY_R)</R>
        </macros>
        <file>../epik8s-opi/unimot-opi/motor-asyn/Motor_Main.bob</file>
        <target>window</target>
      </action>
    </actions>
    <background_color><color red="30" green="110" blue="60"></color></background_color>
    <foreground_color><color red="255" green="255" blue="255"></color></foreground_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>note</name>
    <text>Visualization logic: read centroid and overlay geometry, compute errX/errY in the soft IOC, scale with gain_x/gain_y, move HMIR and VMIR, stop when both errors are inside tolerance.</text>
    <x>420</x>
    <y>752</y>
    <width>700</width>
    <height>64</height>
    <wrap_words>true</wrap_words>
    <font>
      <font family="Liberation Sans" style="BOLD" size="14.0"></font>
    </font>
  </widget>
</display>