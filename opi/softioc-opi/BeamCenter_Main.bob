  <widget type="label" version="2.0.0"><name>s7</name><text>Overlay SizeX</text><x>34</x><y>662</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>osx</name><pv_name>$(CAMERA):Overlay1:1:SizeX_RBV</pv_name><x>150</x><y>658</y><width>100</width><height>26</height><precision>0</precision></widget>
  <widget type="label" version="2.0.0"><name>s8</name><text>Overlay SizeY</text><x>34</x><y>694</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>osy</name><pv_name>$(CAMERA):Overlay1:1:SizeY_RBV</pv_name><x>150</x><y>690</y><width>100</width><height>26</height><precision>0</precision></widget>
  <widget type="label" version="2.0.0"><name>s9</name><text>HMIR RBV</text><x>34</x><y>748</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>mxrbv</name><pv_name>$(MOTX).RBV</pv_name><x>150</x><y>744</y><width>100</width><height>26</height><precision>4</precision></widget>
  <widget type="label" version="2.0.0"><name>s10</name><text>VMIR RBV</text><x>34</x><y>780</y><width>100</width><height>22</height></widget>
