  <widget type="textupdate" version="2.0.0"><name>a2sy</name><pv_name>$(CAMERA):Overlay1:1:SizeY_RBV</pv_name><x>1380</x><y>332</y><width>72</width><height>26</height><precision>0</precision></widget>

