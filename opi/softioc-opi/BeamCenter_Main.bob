<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>Beam Center Control</name>
  <macros>
    <PREFIX>$(PREFIX=LAB:SIM:BEAM_CENTER)</PREFIX>
    <CAMERA>$(CAMERA=LAB:SIM:CAM01)</CAMERA>
    <DEVICE>$(DEVICE=LAB:SIM)</DEVICE>
    <CAM>$(CAM=CAM01)</CAM>
    <MOTX>$(MOTX=LAB:SIM:HMIR)</MOTX>
    <MOTX_P>$(MOTX_P=LAB:SIM)</MOTX_P>
    <MOTX_R>$(MOTX_R=HMIR)</MOTX_R>
    <MOTY>$(MOTY=LAB:SIM:VMIR)</MOTY>
    <MOTY_P>$(MOTY_P=LAB:SIM)</MOTY_P>
    <MOTY_R>$(MOTY_R=VMIR)</MOTY_R>
  </macros>
  <width>1540</width>
  <height>930</height>
  <background_color>
    <color red="237" green="236" blue="235">
    </color>
  </background_color>
  <grid_step_x>5</grid_step_x>
  <grid_step_y>5</grid_step_y>
  <widget type="rectangle" version="2.0.0">
    <name>header</name>
    <width>1540</width>
    <height>52</height>
    <background_color>
      <color red="30" green="110" blue="60">
      </color>
    </background_color>
    <line_color>
      <color red="30" green="110" blue="60">
      </color>
    </line_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>title</name>
    <text>Beam Center Control - $(PREFIX)</text>
    <x>16</x>
    <y>10</y>
    <width>900</width>
    <height>28</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255">
      </color>
    </foreground_color>
  </widget>
  <widget type="rectangle" version="2.0.0">
    <name>controls-bg</name>
    <x>18</x>
    <y>72</y>
    <width>380</width>
    <height>320</height>
    <background_color>
      <color red="250" green="250" blue="250">
      </color>
    </background_color>
  </widget>
  <widget type="label" version="2.0.0"><name>controls-title</name><text>Loop Controls</text><x>32</x><y>88</y><width>180</width><height>24</height><font><font family="Liberation Sans" style="BOLD" size="18.0"></font></font></widget>
  <widget type="label" version="2.0.0"><name>c1</name><text>gain_x</text><x>34</x><y>130</y><width>90</width><height>22</height></widget>
  <widget type="textentry" version="3.0.0"><name>gainx</name><pv_name>$(PREFIX):gain_x</pv_name><x>150</x><y>126</y><width>110</width><height>26</height><precision>4</precision></widget>
  <widget type="label" version="2.0.0"><name>c2</name><text>gain_y</text><x>34</x><y>166</y><width>90</width><height>22</height></widget>
  <widget type="textentry" version="3.0.0"><name>gainy</name><pv_name>$(PREFIX):gain_y</pv_name><x>150</x><y>162</y><width>110</width><height>26</height><precision>4</precision></widget>
  <widget type="label" version="2.0.0"><name>c3</name><text>tolerance</text><x>34</x><y>202</y><width>90</width><height>22</height></widget>
  <widget type="textentry" version="3.0.0"><name>tol</name><pv_name>$(PREFIX):tolerance</pv_name><x>150</x><y>198</y><width>110</width><height>26</height><precision>1</precision></widget>
  <widget type="label" version="2.0.0"><name>c4</name><text>interval</text><x>34</x><y>238</y><width>90</width><height>22</height></widget>
  <widget type="textentry" version="3.0.0"><name>interval</name><pv_name>$(PREFIX):interval</pv_name><x>150</x><y>234</y><width>110</width><height>26</height><precision>1</precision></widget>
  <widget type="bool_button" version="2.0.0">
    <name>start</name>
    <pv_name>$(PREFIX):start</pv_name>
    <x>34</x>
    <y>286</y>
    <width>132</width>
    <height>34</height>
    <on_label>Running</on_label>
    <off_label>Start</off_label>
    <on_color><color red="30" green="210" blue="0"></color></on_color>
    <off_color><color red="77" green="77" blue="77"></color></off_color>
  </widget>
  <widget type="bool_button" version="2.0.0">
    <name>stop</name>
    <pv_name>$(PREFIX):stop</pv_name>
    <x>182</x>
    <y>286</y>
    <width>132</width>
    <height>34</height>
    <on_label>Stopping</on_label>
    <off_label>Stop</off_label>
    <on_color><color red="220" green="60" blue="60"></color></on_color>
    <off_color><color red="77" green="77" blue="77"></color></off_color>
  </widget>
  <widget type="label" version="2.0.0"><name>c5</name><text>Status</text><x>34</x><y>338</y><width>90</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>status</name><pv_name>$(PREFIX):status</pv_name><x>150</x><y>334</y><width>210</width><height>26</height></widget>
  <widget type="rectangle" version="2.0.0">
    <name>state-bg</name>
    <x>18</x>
    <y>414</y>
    <width>380</width>
    <height>490</height>
    <background_color>
      <color red="250" green="250" blue="250">
      </color>
    </background_color>
  </widget>
  <widget type="label" version="2.0.0"><name>state-title</name><text>Live State</text><x>32</x><y>430</y><width>180</width><height>24</height><font><font family="Liberation Sans" style="BOLD" size="18.0"></font></font></widget>
  <widget type="label" version="2.0.0"><name>s1</name><text>errX</text><x>34</x><y>470</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>errx</name><pv_name>$(PREFIX):errX</pv_name><x>150</x><y>466</y><width>100</width><height>26</height><precision>1</precision></widget>
  <widget type="label" version="2.0.0"><name>s2</name><text>errY</text><x>34</x><y>502</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>erry</name><pv_name>$(PREFIX):errY</pv_name><x>150</x><y>498</y><width>100</width><height>26</height><precision>1</precision></widget>
  <widget type="label" version="2.0.0"><name>s3</name><text>CentroidX</text><x>34</x><y>534</y><width>100</width><height>22</height></widget>
  <widget type="textupdate" version="2.0.0"><name>cx</name><pv_name>$(CAMERA):Stats1:CentroidX_RBV</pv_name><x>150</x><y>530</y><width>100</width><height>26</height><precision>1</precision></widget>
