  <widget type="embedded" version="2.0.0">
    <name>camera-view</name>
    <file>../epik8s-opi/unicam-opi/Camera_ColorImagePanel.bob</file>
    <x>420</x>
    <y>72</y>
    <width>720</width>
    <height>610</height>
    <resize>0</resize>
    <macros>
      <DEVICE>$(DEVICE)</DEVICE>
      <CAM>$(CAM)</CAM>
      <DID>BEAMCENTER</DID>
    </macros>
  </widget>
  <widget type="rectangle" version="2.0.0"><name>algo-bg</name><x>1160</x><y>72</y><width>360</width><height>832</height><background_color><color red="250" green="250" blue="250"></color></background_color></widget>
  <widget type="label" version="2.0.0"><name>algo-title</name><text>Algorithm Visualization</text><x>1178</x><y>88</y><width>260</width><height>24</height><font><font family="Liberation Sans" style="BOLD" size="18.0"></font></font></widget>

  <widget type="rectangle" version="2.0.0"><name>a1b</name><x>1180</x><y>130</y><width>320</width><height>94</height><background_color><color red="238" green="246" blue="255"></color></background_color></widget>
